{
	"name": "ts-support",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"gen": "turbo gen",
		"ts:check": "turbo run ts:check",
		"prepublish": "turbo run build && changeset version"
	},
	"overrides": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.4",
		"@changesets/cli": "^2.29.5",
		"@turbo/gen": "^2.5.5",
		"tsup": "^8.5.0",
		"turbo": "^2.5.5",
		"typescript": "^5.9.2"
	},
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalog": {
			"zod": "^4.0.17"
		}
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.2.20"
}
