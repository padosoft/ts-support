{
	"name": "ts-support",
	"private": true,
	"repository": {
		"url": "git+https://github.com/padosoft/ts-support.git"
	},
	"scripts": {
		"build": "turbo run build",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"gen": "turbo gen",
		"test": "bun test",
		"ts:check": "turbo run ts:check",
		"version-packages": "changeset version && bun i --ignore-scripts --lockfile-only",
		"publish-packages": "bun run build && changeset version && changeset publish"
	},
	"overrides": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@turbo/gen": "^2.8.20",
		"@types/bun": "1.3.11",
		"tsdown": "^0.21.4",
		"turbo": "^2.8.20",
		"typescript": "^6.0.2"
	},
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalog": {
			"zod": "^4.1.11"
		}
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"packageManager": "bun@1.2.20"
}
