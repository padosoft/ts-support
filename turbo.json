{
	"$schema": "https://turbo.build/schema.v2.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"cache": true,
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "src/**/*.ts", ".env*", "tsdown.config.ts"],
			"outputs": ["dist/**"]
		},
		"ts:check": {
			"dependsOn": ["^ts:check"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
