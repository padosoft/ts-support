{
	"name": "@padosoft/openapi-client",
	"description": "Typed base client for openapi-fetch with middleware support, error handling, and a clean extension model",
	"keywords": ["openapi", "openapi-fetch", "typescript", "rest", "http-client", "padosoft"],
	"version": "1.0.0",
	"type": "module",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"repository": {
		"url": "git+https://github.com/padosoft/ts-support.git"
	},
	"scripts": {
		"build": "tsdown",
		"ts:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@padosoft/config": "workspace:^"
	},
	"dependencies": {
		"@padosoft/utilities": "^1.4.0",
		"openapi-fetch": "^0.17.0",
		"openapi-typescript-helpers": "^0.1.0"
	},
	"exports": {
		".": {
			"default": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./lib": {
			"default": "./dist/lib/index.mjs",
			"types": "./dist/lib/index.d.mts"
		},
		"./lib/base": {
			"default": "./dist/lib/base.mjs",
			"types": "./dist/lib/base.d.mts"
		},
		"./types": {
			"default": "./dist/types/index.mjs",
			"types": "./dist/types/index.d.mts"
		},
		"./types/base": {
			"default": "./dist/types/base.mjs",
			"types": "./dist/types/base.d.mts"
		},
		"./package.json": "./package.json"
	}
}
