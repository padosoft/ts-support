{
	"name": "@padosoft/config",
	"type": "module",
	"version": "1.1.2",
	"publishConfig": {
		"access": "restricted",
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"url": "git+https://github.com/padosoft/ts-support.git"
	},
	"scripts": {
		"build": "tsdown",
		"ts:check": "tsc --noEmit"
	},
	"exports": {
		"./plugins/*": {
			"default": "./dist/plugins/*.js",
			"types": "./dist/plugins/*.d.ts"
		},
		"./tsdown": {
			"default": "./dist/tsdown.js",
			"types": "./dist/tsdown.d.ts"
		},
		"./utils": {
			"default": "./dist/utils/index.js",
			"types": "./dist/utils/index.d.ts"
		},
		"./utils/exports": {
			"default": "./dist/utils/exports.js",
			"types": "./dist/utils/exports.d.ts"
		},
		"./package.json": "./package.json",
		"./typescript/*": "./typescript/*.json",
		"./tools/biome": "./tools/biome.json"
	},
	"dependencies": {}
}
