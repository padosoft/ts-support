{
	"name": "@padosoft/utilities",
	"version": "1.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"publishConfig": {
		"access": "restricted",
		"registry": "https://npm.pkg.github.com"
	},
	"scripts": {
		"build": "tsup",
		"ts:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@padosoft/config": "workspace:^"
	},
	"dependencies": {},
	"peerDependencies": {
		"zod": "^3.25.0 || ^4.0.0"
	}
}
